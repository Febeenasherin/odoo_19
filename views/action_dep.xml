<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!--    form view -->
    <record model="ir.ui.view" id="dep_view_form">
        <field name="name">ir.demo.form</field>
        <field name="model">school.department</field>
        <field name="arch" type="xml">
            <form>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="dep_partner"/>


                    </group>


                </sheet>
            </form>
        </field>

    </record>




    <record  model="ir.ui.view"  id="dep_view_list">
        <field name="name">ir.demo.list</field>
        <field name="model">school.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="dep_partner"/>

            </list>
        </field>
    </record>




        <record id="action_dep" model="ir.actions.act_window">
        <field name="name">Department</field>
        <field name="res_model">school.department</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="view_content">
                no record found.
            </p>
        </field>
        </record>
</odoo>






