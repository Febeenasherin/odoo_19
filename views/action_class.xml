<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--form-->
    <record id="class_view_form" model="ir.ui.view">
        <field name="name">ir.demo.form</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                <group>

                        <field name="name"/>
                        <field name="school_dep"/>



                </group>
                </sheet>
            </form>
        </field>
    </record>

<!--    list-->
    <record model="ir.ui.view" id="class_view_list">
        <field name="name">ir.demo.list</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="school_dep"/>
            </list>
        </field>
    </record>



    <record id="action_class" model="ir.actions.act_window">
        <field name="name">Class</field>
        <field name="res_model">school.class</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent">
                No record found !
            </p>

        </field>
     </record>



</odoo>
