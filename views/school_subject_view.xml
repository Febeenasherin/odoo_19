<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--    form-->
    <record id="school_subject_view_form" model="ir.ui.view">
        <field name="name">ir.demo.form</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <form>

                <sheet>
                    <group>

                        <field name="name_sub"/>
                        <field name="school_dep"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>

    </record>
    <!--    list-->
    <record  id="school_subject_view_list" model="ir.ui.view">
        <field name="name">ir.demo.list</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="name_sub"/>
                <field name="school_dep"/>
            </list>
        </field>
    </record>

    <record id="school_subject_action"  model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">school.subject</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="view_content">
                no record found.
            </p>
        </field>
        </record>

</odoo>
