<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--    form-->
    <record model="ir.ui.view" id="sub_view_form">
        <field name="name">ir.demo.form</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <form>

                <sheet>
                    <group>

                        <field name="name"/>
                        <field name="school_dep"/>



                    </group>


                </sheet>
            </form>
        </field>

    </record>



    <!--    list-->
    <record model="ir.ui.view" id="sub_view_list">
        <field name="name">ir.demo.list</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="school_dep"/>
            </list>
        </field>
    </record>







    <record id="action_subject"  model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">school.subject</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="view_content">
                no record found.
            </p>
        </field>
        </record>

</odoo>
