<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!--    form view -->
    <record id="school_department_view_form" model="ir.ui.view">
        <field name="name">ir.demo.form</field>
        <field name="model">school.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="dep_partner"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>

    </record>

    <record id="school_department_view_list" model="ir.ui.view">
        <field name="name">ir.demo.list</field>
        <field name="model">school.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="dep_partner"/>

            </list>
        </field>
    </record>

    <record id="school_department_action" model="ir.actions.act_window">
        <field name="name">Department</field>
        <field name="res_model">school.department</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="view_content">
                no record found.
            </p>
        </field>
        </record>
</odoo>






