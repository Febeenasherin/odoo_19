<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="vendor_product_list" model="ir.ui.view">
       <field name="name">purchase.order.line.view</field>
       <field name="model">purchase.order.line</field>
       <field name="inherit_id" ref="purchase.purchase_order_form"/>
       <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
               <field name="vendor_products"/>


           </xpath>
             <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">

                <attribute name="domain">[ ('vendor_product', '=', True), ('seller_ids.partner_id', '=', parent.partner_id)]</attribute>
             </xpath>

       </field>
   </record>
</odoo>