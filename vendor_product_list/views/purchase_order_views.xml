<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="vendor_product_list_view" model="ir.ui.view">
       <field name="name">purchase.order.view</field>
       <field name="model">purchase.order</field>
       <field name="inherit_id" ref="purchase.purchase_order_form"/>
       <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
              <field name="vendor_products"/>
           </xpath>
           <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
               <attribute name="domain">[('id', 'in', product_ids)]</attribute>
           </xpath>


       </field>
   </record>
</odoo>
