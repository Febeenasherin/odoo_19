<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <data>
       <record model="ir.module.category" id="module_category_school_management">
           <field name="name">School</field>
           <field name="sequence">5</field>
       </record>
       <record model="res.groups.privilege" id="res_groups_privilege_school_management">
           <field name="name">School Management</field>
           <field name="category_id" ref="school_management.module_category_school_management"/>
       </record>

<!--       student group -->
       <record id="group_school_student" model="res.groups">
           <field name="name">Student</field>
           <field name="privilege_id" ref="res_groups_privilege_school_management" />
           <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
       </record>
       <!-- office staff -->
       <record id="group_school_office_staff" model="res.groups">
           <field name="name">Office staff</field>
           <field name="privilege_id" ref="res_groups_privilege_school_management" />
           <field name="implied_ids" eval="[(4, ref('group_school_teacher'))]" />
       </record>
<!--       teacher -->
       <record id="group_school_teacher" model="res.groups">
           <field name="name">Teacher</field>
           <field name="privilege_id" ref="res_groups_privilege_school_management" />
           <field name="implied_ids" eval="[(4, ref('group_school_student'))]" />
       </record>

   </data>
</odoo>
