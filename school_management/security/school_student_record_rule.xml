<?xml version="1.0" encoding="UTF-8"?>
<odoo>
   <record id="school_student_record_rule" model="ir.rule">
       <field name="name">User can only see their own records</field>
       <field ref="model_school_students" name="model_id"/>
       <field name="domain_force">[('user_id', '=', user.id)]</field>
       <field name="groups" eval="[(4, ref('school_management.group_school_student'))]"/>
       <field name="perm_read" eval="True"/>
       <field name="perm_write" eval="False"/>
       <field name="perm_create" eval="False"/>
       <field name="perm_unlink" eval="False"/>
</record>

       <record id="school_student_exam_rule" model="ir.rule">
