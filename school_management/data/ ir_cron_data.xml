<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <record id="cron_event_reminder" model="ir.cron">
            <field name="name">Event Reminder</field>
            <field name="model_id" ref="model_school_events"/>
            <field name="state">code</field>
            <field name="code">model.auto_send_email()</field>
<!--            <field name="user_id" ref="base.user_root"/>-->
            <field name="interval_number">2</field>
            <field name="interval_type">days</field>
<!--            <field name="nextcall" eval="(DateTime.now() + timedelta(days=2)).strftime('%Y-%m-%d 09:00:00')" />-->
            <field name="priority">5</field>
            <field name="active">True</field>
        </record>

</odoo>


