<?xml version="1.0" encoding="utf-8" ?>

<odoo>

    <record id="sequence_reg" model="ir.sequence">
        <field name="name">sequence</field>
        <field name="code">sequencecode</field>
        <field name="prefix">RN</field>
        <field name="padding">3</field>
        <field name="number_increment">1</field>
    </record>

     <record id="admission_no" model="ir.sequence">
        <field name="name">admission</field>
        <field name="code">admissioncode</field>
        <field name="prefix">AD</field>
        <field name="padding">3</field>
        <field name="number_increment">1</field>
     </record>
</odoo>