<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="leave_information_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <h2 class="text-center">LEAVE  REPORT</h2>
                    <hr/>
                    <div class="row mb-4">
                        <div class="col-6">
                            <strong>DATE: </strong>
                            <span t-esc="print_date"/>
                        </div>
                        <div class="col-3">
                            <strong>TYPE: </strong>
                            <span t-esc="type"/>
                        </div>
                        <div class="col-3" t-if="class_name">
                            <strong>Class: </strong>
                            <span t-esc="class_name"/>
                        </div>
                    </div>
                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th>Sl.no</th>
                                <th>Name</th>
                                <th>Admission No</th>
                                <th>Class</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Total Days</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="leave">
                                <tr>
                                    <td><span t-esc="leave_index + 1"/></td>
                                    <td><span t-esc="leave[1]"/></td>
                                    <td><span t-esc="leave[0]"/></td>
                                    <td><span t-esc="leave[2]"/></td>
                                    <td><span t-esc="leave[3]"/></td>
                                    <td><span t-esc="leave[4]"/></td>
                                    <td><span t-esc="leave[5]"/></td>
                                    <td><span t-esc="leave[6]"/></td>
                                </tr>

                            </t>
                        </tbody>
                    </table>
<!--                    <div class="mt-3">-->
<!--                        <strong>Total Tasks: </strong>-->
<!--                        <span t-esc="len(docs)"/>-->
<!--                    </div>-->
                </div>
            </t>
        </t>
    </template>
</odoo>


