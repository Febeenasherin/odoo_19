<?xml version="1.0" encoding="UTF-8"?>
<odoo>
   <template id="partner_details_template">
       <t t-call="web.external_layout">
           <main>
           <t t-foreach="docs" t-as="partner">
               <div class="page">
                   <h2>leave information</h2>
                   <hr/>
                   <p><strong>Name:</strong> <t t-esc="student_id"/></p>
                   <p><strong>Email:</strong> <t t-esc=".email or 'N/A'"/></p>
                   <p><strong>Phone:</strong> <t t-esc="partner.phone or 'N/A'"/></p>
                   <p><strong>Company:</strong> <t t-esc="partner.company_name or 'N/A'"/></p>
                   <p><strong>Address:</strong>
                       <t t-esc="partner.street or ''"/>
                       <t t-esc="partner.street2 or ''"/><br/>
                       <t t-esc="partner.city or ''"/> -
                       <t t-esc="partner.zip or ''"/><br/>
                       <t t-esc="partner.country_id.name or ''"/>
                   </p>
               </div>
           </t>
           </main>
       </t>
   </template>
</odoo>
