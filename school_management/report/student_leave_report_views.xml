<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="leave_information_template">

            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Leave Information</h2>


                    <t t-foreach="docs" t-as="leave">
                        <h3 t-esc="month"/>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Class</th>
                                    <th>Star Date</th>
                                    <th>End Date</th>
                                    <th>Total Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="leave">
                                    <tr>
                                        <td><span t-field="leave.student_id.first_name"/></td>
                                        <td><span t-field="leave.class_id.name_class"/></td>
                                        <td><span t-field="leave.start_date"/></td>
                                        <td><span t-field="leave.end_date"/></td>
<!--                                        <td><span t-field="leave.total_date"/></td>-->

                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        
    </template>
</odoo>

