<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="clubs_data_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <h2 class="text-center">CLUB REPORT</h2>
                    <hr/>

                    <div class="row mb-4">
                        <div class="col-6">
                            <strong>Print Date: </strong>
                            <span t-esc="print_date"/>
                        </div>
                        <div class="col-3" t-if="club_name">
                            <strong>CLUB: </strong>
                            <span t-esc="club_name"/>
                        </div>

                        <div class="col-3" t-if="student_name">
                            <strong>Student name: </strong>
                            <span t-esc="student_name"/>
                        </div>
                    </div>
                     <div class="oe_structure"/>
                    <h6 class="text-left">Student details:</h6>
                    <hr/>
                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th><strong>Sl.no</strong></th>
                                <th t-if="club"><strong>Name</strong></th>
                                <th><strong>Admission No</strong></th>
                                <th><strong>Class</strong></th>
                                <th t-if="clubs"><strong>Club</strong></th>

                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="students" t-as="st">
                                <tr>
                                    <td><span t-esc="st_index + 1"/></td>
                                    <td t-if="club"><span t-esc="st[0]"/></td>
                                    <td><span t-esc="st[1]"/></td>
                                    <td><span t-esc="st[2]"/></td>
                                    <td t-if="clubs"><span t-esc="st[3]"/></td>

                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="oe_structure" t-if="event"/>
                    <h6 class="text-left" t-if="event">Events:</h6>
                    <hr/>
                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th t-if="event"><strong>Sl.no</strong></th>
                                <th t-if="event"><strong>Club</strong></th>
                                <th t-if="event"><strong>Name</strong></th>
                                <th t-if="event"><strong>Venue</strong></th>
                                <th t-if="event"><strong>Start date</strong></th>
                                <th t-if="event"><strong>End date</strong></th>

                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="event" t-as="event">
                                <tr>
                                    <td><span t-esc="event_index + 1"/></td>
                                    <td><span t-esc="event[4]"/></td>
                                    <td><span t-raw="event[0]"/></td>
                                    <td><span t-raw="event[1]"/></td>
                                    <td><span t-esc="event[2]"/></td>
                                    <td><span t-esc="event[3]"/></td>

                                </tr>

                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>


