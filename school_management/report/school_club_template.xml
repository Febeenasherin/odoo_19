<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="clubs_data_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <h2 class="text-center">CLUB REPORT</h2>
                    <hr/>

                    <div class="row mb-4">
                        <div class="col-6">
                            <strong>DATE: </strong>
                            <span t-esc="print_date"/>
                        </div>
                        <div class="col-3" t-if="club_name">
                            <strong>CLUB: </strong>
                            <span t-esc="club_name"/>
                        </div>

<!--                        <div class="col-3" t-if="student_name">-->
<!--                            <strong> </strong>-->
<!--                            <span t-esc="student_name"/>-->
<!--                        </div>-->

<!--                        <div class="row mb-5">-->
<!--                            <strong>Student details: </strong>-->
<!--&lt;!&ndash;                            <span t-esc="print_date"/>&ndash;&gt;-->
<!--                        </div>-->
<!--                        <div class="col-3" t-if="class_name">-->
<!--                            <strong>Class: </strong>-->
<!--                            <span t-esc="class_name"/>-->
<!--                        </div>-->
                    </div>
                     <div class="oe_structure"/>
                    <h5 class="text-left">Student details:</h5>
                    <hr/>



                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th>Sl.no</th>
                                <th>Name</th>
                                <th>Admission No</th>
                                <th>Class</th>

                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="students" t-as="st">
                                <tr>
                                    <td><span t-esc="st_index + 1"/></td>
                                    <td><span t-esc="st[0]"/></td>
                                    <td><span t-esc="st[1]"/></td>
                                    <td><span t-esc="st[2]"/></td>

                                </tr>

                            </t>
                        </tbody>
                    </table>

                    <div class="oe_structure"/>
                    <h5 class="text-left">Events:</h5>
                    <hr/>



                    <table class="table table-bordered table-sm">
                        <thead class="table-primary">
                            <tr>
                                <th>Sl.no</th>
                                <th>Name</th>
                                <th>Venue</th>
                                <th>Start date</th>
                                <th>End date</th>

                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="event" t-as="event">
                                <tr>
                                    <td><span t-esc="event_index + 1"/></td>
                                    <td><span t-esc="env['ir.fields.converter'].text_from_html(event.venue)"/></td>
                                    <td><span t-esc="event[1]"/></td>
                                    <td><span t-esc="event[2]"/></td>
                                    <td><span t-esc="event[3]"/></td>

                                </tr>

                            </t>
                        </tbody>
                    </table>

                </div>
            </t>
        </t>
    </template>
</odoo>


