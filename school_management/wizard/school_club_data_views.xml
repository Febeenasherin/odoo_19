<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<record id="school_club_wizard_form" model="ir.ui.view">
   <field name="name">school.club.wizard</field>
   <field name="model">school.club.data</field>
   <field name="arch" type="xml">
       <form string="Club Data">
            <sheet>
                    <group>
                        <field name="club_id"/>
                        <field name="student_id"/>
                    </group>
                    <footer>
                        <button string="Print PDF"
                                name="action_club_print"
                                type="object"
                                class="btn-primary"/>
                        <button string="Print XLSX"
                                name="club_excel"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
           </sheet>
       </form>
   </field>
</record>


</odoo>
