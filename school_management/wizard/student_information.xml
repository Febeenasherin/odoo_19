<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<record id="student_information_wizard_form" model="ir.ui.view">
   <field name="name">student.information.wizard</field>
   <field name="model">student.information</field>
   <field name="arch" type="xml">
       <form string="Student information">
                    <sheet>
                    <group>
                        <field name="class_id"/>
                        <field name="department_id"/>


                    </group>
                    <footer>
                        <button string="Print PDF"
                                name="action_print_student_information"
                                type="object"
                                class="btn-primary"/>
                        <button string="Print XLSX"
                                name="student_xlsx"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </sheet>
       </form>
   </field>
</record>


</odoo>
