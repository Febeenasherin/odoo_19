<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="student_leave_wizard_form" model="ir.ui.view">
        <field name="name">student.leave.wizard</field>
        <field name="model">student.leave.wizard</field>
        <field name="arch" type="xml">
            <form string="Leave Report">
                <sheet>
                    <group>
                        <field name="filter_type"/>
                        <field name="student_id"/>
                        <field name="class_id"/>
                        <field name="start_date" invisible="filter_type !='custom'"/>
                        <field name="end_date" invisible="filter_type !='custom'"/>

                    </group>
                    <footer>
                        <button string="Print"
                                name="action_print"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>