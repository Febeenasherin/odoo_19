<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    form view -->
    <record id="school_events_view_form" model="ir.ui.view">
        <field name="name">schoo.events.form</field>
        <field name="model">school.events</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_ongoing" type="object" string="Start" class="oe_highlight"/>
                    <button name="action_completed" type="object" string="Done" class="oe_highlight"/>
                    <field name="status" widget="statusbar" options="{'clickable':0}"/>

                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="venue"/>
                        <field name="club_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="school_events_action" model="ir.actions.act_window">
        <field name="name">Events</field>
        <field name="res_model">school.events</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_j">
                No record found .
            </p>
        </field>
    </record>
</odoo>
