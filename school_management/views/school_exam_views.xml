<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--form-->
    <record id="school_exam_view_form" model="ir.ui.view">
        <field name="name">school.exam.form</field>
        <field name="model">school.exam</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="add_action" string="Add"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="class_id"/>
                    </group>
                    <group>
                        <notebook>
                            <page name="Papers" string="Papers">
                                <field name="paper_ids">
                                    <list editable="bottom">
                                        <field name="subject_id"/>
                                        <field name="pass_mark"/>
                                        <field name="max_mark"/>

                                    </list>
                                </field>
                            </page>
                        </notebook>

                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!--    list-->
    <record id="school_exam_view_list" model="ir.ui.view">
        <field name="name">school.exam.list</field>
        <field name="model">school.exam</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="class_id"/>
                <field name="subject_id"/>
            </list>
        </field>
    </record>

    <record id="school_exam_action" model="ir.actions.act_window">
        <field name="name">Exams</field>
        <field name="res_model">school.exam</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>