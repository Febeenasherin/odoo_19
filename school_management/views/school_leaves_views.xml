<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="school_leaves_view_form" model="ir.ui.view">
        <field name="name">schoo.leave.form</field>
        <field name="model">school.leaves</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                    <group>
                        <field name="student_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        <field name="start_date"/>
                        <field name="total_date"/>
                        <field name="half_day"/>
                        <field name="afternoon" invisible="not half_day"/>
                    </group>
                    <group>
                        <field name="class_id"/>
                        <field name="end_date"/>
                        <field name="reason"/>
                    </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

<record id="school_leaves_view_list" model="ir.ui.view">
        <field name="name">school.leaves.list</field>
        <field name="model">school.leaves</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="reason"/>
                <field name="half_day"/>
            </list>
        </field>
    </record>


    <record id="school_leaves_action" model="ir.actions.act_window">
        <field name="name">Leaves</field>
        <field name="res_model">school.leaves</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>