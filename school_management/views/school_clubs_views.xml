<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    form view -->
    <record id="school_clubs_view_form" model="ir.ui.view">
        <field name="name">schoo.clubs.form</field>
        <field name="model">school.clubs</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                         <button name="action_open_events" type="object" class="oe_stat_button" icon="fa-star">
                                <div class="o_stat_info">
                                    <field name="event_count" class="o_stat_value"/>
                                    <span class="o_stat_text">Events</span>
                                </div>
                            </button>
                    </div>
                    <group>
                        <field name="name"/>
                    </group>
                    <notebook>
                        <page string="Students">
                                  <field name="student_ids"/>
                            </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!--    list view-->
    <record id="school_clubs_view_list" model="ir.ui.view">
        <field name="name">school.clubs.list</field>
        <field name="model">school.clubs</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_ids"/>
            </list>
        </field>
    </record>

    <record id="school_clubs_action" model="ir.actions.act_window">
        <field name="name">Clubs</field>
        <field name="res_model">school.clubs</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
