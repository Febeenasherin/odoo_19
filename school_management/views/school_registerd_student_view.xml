<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record  id="school_registerd_view_form" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.students</field>
        <field name="arch" type="xml">
            <form edit="0" create="0">


                <sheet>
                    <h1>
                        <h1> <field name="admission" readonly="1"/>
                    </h1>
                    </h1>

                <group>
                    <group>
                        <field name="first_name"/>
                        <field name="last_name"/>
                        <field name="email"/>
                        <field name="attendance"/>
                    </group>
                    <group>
                        <field name="class_id"/>
                        <field name="phone_no"/>
                        <field name="sequence"/>

                    </group>
                    <group>

                    </group>
                </group>
                                            <notebook>

                             <page string="Exams">

                                <field name="exam_ids" nolable="1"/>

                        </page>
                        </notebook>
                </sheet>
            </form>
        </field>
</record>
    <record id="school_register_list" model="ir.ui.view">
        <field name="name">school.student.list</field>
        <field name="model">school.students</field>
        <field name="arch" type="xml">
            <list string="school_management"
                            decoration-danger="attendance == 'absent'"
                            decoration-success="attendance == 'present'" >

                        <field name="admission"/>
                        <field name="first_name"/>
                        <field name="last_name"/>

            </list>
        </field>
    </record>



     <record id="school_registerd_student_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.students</field>
        <field name="view_mode">list,form</field>
         <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'list', 'view_id': ref('school_register_list')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('school_registerd_view_form')})]"/>
         <field name="domain">[('status' , '=' , 'registration')]</field>
         <field name="context">{'create' : False}</field>



     </record>
</odoo>


