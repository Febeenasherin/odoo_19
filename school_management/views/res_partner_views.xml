<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="view_partner_form_inherit_customer_type" model="ir.ui.view">
       <field name="name">res.partner.form.inherit.customer.type</field>
       <field name="model">res.partner</field>
       <field name="inherit_id" ref="base.view_partner_form"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='category_id']" position="after">
               <field name="partner"/>
           </xpath>
       </field>
   </record>
<!-- teacher action-->
    <record id="res_partner_teachers_action" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent">
                No record found !
            </p>
        </field>
        <field name="domain">[('partner', '=' , 'teacher')]</field>
        <field name="context">{'default_partner':'teacher'}</field>

    </record>

<!--    office staff action-->

    <record id="res_partner_officestaff_action" model="ir.actions.act_window">
        <field name="name">Office staff</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent">
                No record found !
            </p>

        </field>
        <field name="domain">[('partner', '=' , 'office staff')]</field>
        <field name="context">{'default_partner':'office staff'}</field>
    </record>

<!--    email template-->
   <record id="email_template_event" model="mail.template">
       <field name="name">Event Reminder</field>
       <field name="model_id" ref="base.model_res_partner"/>
       <field name="subject">Event Reminder</field>
       <field name="email_from">noreply@example.com</field>
       <field name="email_to">{{object.email}}</field>
       <field name="body_html" type="html">
               <p>Hi <t t-out="object.name"/>,</p>
               <p>This is a reminder to attend the event.</p>
               <p><strong>Please make sure you come on time.</strong></p>
               <br/>
               <p>Best regards,<br/>School Team</p>
       </field>
   </record>

<!--   schedule action-->
 <record id="cron_student_homework_reminder" model="ir.cron">
       <field name="name">Event Reminder</field>
       <field name="model_id" ref="base.model_res_partner"/>
       <field name="state">code</field>
       <field name="code">model.send_student_event_reminder()</field>
       <field name="interval_number">2</field>
       <field name="interval_type">days</field>
       <field name="active" eval="True"/>

   </record>
</odoo>



