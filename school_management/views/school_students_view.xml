<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    form view -->
    <record  id="school_students_view_form" model="ir.ui.view">
        <field name="name">school.students.form</field>
        <field name="model">school.students</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_registration" type="object" string="Register" class="oe_highlight"
                            groups="school_management.group_school_office_staff,school_management.group_school_teacher"/>
                    <field name="status" widget="statusbar" options="{'clickable':0}"/>
                    
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <h1> <field name="sequence" readonly="1"/>
                    </h1>
                <group>
                    <group>
                        <field name="admission" invisible="status !='registration'"/>
                        <field name="first_name"/>
                        <field name="last_name"/>
                        <field name="father_name"/>
                        <field name="mother_name"/>
                        <field name="email"/>
                        <field name="school_id"/>
                        <field name="aadhaar_no"/>
                    </group>
                    <group>
                        <field name="phone_no"/>
                        <field name="dob"/>
                        <field name="student_age"/>
                        <field name="gender"/>
                        <field name="registration_date"/>
                        <field name="company_id" />
                        <field name="club_ids" widget="many2many_tags"/>
                        <field name="class_id"/>

                    </group>
                    </group>
                    <group>
                    <notebook>
                            <page string="Personal information" name="personal_information">
                                <group>
                                    <span class="o_form_label 0_td_label o_address_type fw_bold" >Communication address</span>
                                    <div class="o_address_format">
                                        <field name="street" placeholder="Street..."/>
                                        <field name="city" placeholder="City"/>
                                        <field name="country_id" placeholder="Country"/>
                                    </div>
                                    <field name="same_as_communication" widget="boolean_toggle"/>
                                    <span class="o_form_label 0_td_label o_address_type fw_bold"
                                          invisible="same_as_communication">permanent address</span>
                                <div class="o_address_format" invisible="same_as_communication">
                                        <field name="street" placeholder="Street..." />
                                        <field name="city" placeholder="City"/>
                                        <field name="country_id" placeholder="Country"/>
                                </div>
                                </group>
                            </page>
                        <page string="Previous school data" name="previous_data">
                            <group>
                                <field name="previous_department_id"/>
                                <field name="previous_class_id" domain="[('school_id' ,'=', previous_department_id)]"/>
                                <field name="document" filename="certificate_filename"/>
                            </group>
                        </page>

                    </notebook>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!--    list view -->
    <record id="school_students_list" model="ir.ui.view">
        <field name="name">school.students.list</field>
        <field name="model">school.students</field>
        <field name="arch" type="xml">
            <list string="school management">

                        <field name="sequence"/>
                        <field name="first_name"/>
                        <field name="last_name"/>
                        <field name="email"/>
                        <field name="phone_no"/>
                        <field name="gender"/>
                        <field name="status"/>
            </list>
        </field>
    </record>

    <record id="school_students_action" model="ir.actions.act_window">
        <field name="name">Registration</field>
        <field name="res_model">school.students</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'list', 'view_id': ref('school_students_list')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('school_students_view_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No record found ! Let's create one
            </p>
        </field>
     </record>
</odoo>
